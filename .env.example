# Keep this file free of real credentials.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
LITMUS_PORT=4173

# Reading GitHub (repos, issues, PRs). A classic PAT with repo scope is enough.
GITHUB_TOKEN=

# Optional: give the bot its own identity so comments post as Litmus[bot]
# instead of as you. Create the App from github-app-manifest.json, install it
# on your repositories, then fill these in. Without them Litmus falls back to
# GITHUB_TOKEN and comments appear under your own account.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=litmus-app.private-key.pem
# Alternative to the path above — paste the PEM with literal \n between lines:
GITHUB_APP_PRIVATE_KEY=
# Optional: skip installation lookup by pinning the installation id.
GITHUB_APP_INSTALLATION_ID=

# Only needed for automatic webhook mode (bot answers volunteers on its own).
GITHUB_WEBHOOK_SECRET=
